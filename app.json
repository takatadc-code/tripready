{
  "expo": {
    "name": "TripReady",
    "slug": "tripready",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tripready",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/app-icon.png",
    "splash": {
      "image": "./assets/images/splash-screen.png",
      "resizeMode": "contain",
      "backgroundColor": "#E0F7FA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.randomcorp.tripready",
      "buildNumber": "1",
      "infoPlist": {
